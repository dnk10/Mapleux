<Window x:Class="caelestia.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:gif="http://wpfanimatedgif.codeplex.com"
        xmlns:local="clr-namespace:caelestia"
        mc:Ignorable="d"
        Height="700"
        Width="500"
        Topmost="True"
        ShowInTaskbar="False"

        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background = "Transparent"
        >

    <Window.Resources>

        <SolidColorBrush x:Key="CardBorderBrush"
                     Color="#A78BFA" />

        <Style x:Key="AnimatedCardStyle"
           TargetType="Border">

            <Setter Property="BorderThickness"
                Value="4" />

            <Setter Property="BorderBrush"
                Value="{StaticResource CardBorderBrush}" />

            <Setter Property="CornerRadius"
                Value="4" />

            <Setter Property="Background"
                Value="#CC1E1E2E" />

        </Style>

        <Style x:Key="animeButtonStyle"
       TargetType="Button">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#181825" />
            <Setter Property="BorderBrush" Value="#6C7086" />
            <Setter Property="BorderThickness" Value="3" />
            <Setter Property="Padding" Value="2" />
            <Setter Property="Margin" Value="7" />
            <Setter Property="FontSize" Value="14" />

            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform />
                </Setter.Value>
            </Setter>

            <Setter Property="Template">
                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="ButtonBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="4">

                            <ContentPresenter
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                             Value="True">

                                <Setter TargetName="ButtonBorder"
                                Property="BorderBrush"
                                Value="#CBA6F7" />

                                <Setter TargetName="ButtonBorder"
                                Property="Background"
                                Value="#45475A" />
                            </Trigger>

                            <Trigger Property="IsPressed"
                             Value="True">

                                <Setter TargetName="ButtonBorder"
                                Property="Background"
                                Value="#585B70" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>

                <Trigger Property="IsMouseOver"
                 Value="True">

                    <Setter Property="Effect">

                        <Setter.Value>

                            <DropShadowEffect
                            BlurRadius="12"
                            ShadowDepth="3"
                            Opacity="0.35" />
                        </Setter.Value>
                    </Setter>

                    <Setter Property="RenderTransform">

                        <Setter.Value>

                            <TranslateTransform Y="3" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="170" />
            <RowDefinition Height="*" />
            <RowDefinition Height="80" />
            <RowDefinition Height="160" />
            <RowDefinition Height="0.4*" />
        </Grid.RowDefinitions>

        <!-- Top Section -->
        <Grid Grid.Row="0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60*" />
                <ColumnDefinition Width="40*" />
            </Grid.ColumnDefinitions>

            <!-- Calendar -->
            <Border Grid.Column="0"
                Margin="0,0,5,0"
                Background="#181825"
                CornerRadius="4"
                Style = "{StaticResource AnimatedCardStyle}"
                x:Name = "calendarCard">


                <StackPanel Margin="10">

                    <TextBlock
                        x:Name="MonthTitle"
                        FontSize="20"
                        FontFamily="JetBrainsMono Nerd Font"
                        FontWeight="Bold"
                        Foreground="#cba6f7"
                        Margin="10,0,0,0" />

                    <UniformGrid
                        x:Name="CalendarGrid"
                        Columns="7"/>
                </StackPanel>
            </Border>

            <!-- Profile -->
            <Border Grid.Column="1"
                Background="#181825"
                CornerRadius="4"
                Style="{StaticResource AnimatedCardStyle}"
                x:Name="profileCard"
                    Padding="0,0,0,0"
                    Margin="0,0,0,0">

                <StackPanel VerticalAlignment="Center">
                    <TextBlock
                        Text="Nithish"
                        HorizontalAlignment="Center"
                        FontSize="14"
                        FontWeight="Bold"
                        FontFamily="JetBrainsMono Nerd Font"
                        Foreground="#fcb5ae"
                        Margin="0 5 0 5" />

                    <Ellipse Width="85"
                         Height="85"
                         Stroke="#cba6f7"
                         StrokeThickness="3"
                         HorizontalAlignment="Center"
                         Margin="0 0 0 10">

                        <Ellipse.Fill>
                            <ImageBrush ImageSource="/Assets/AnimeSets/kou3.jpg" Stretch="UniformToFill" />
                        </Ellipse.Fill>

                        <Ellipse.Effect>
                            <DropShadowEffect BlurRadius="2" ShadowDepth="2" Opacity="0.4" />
                        </Ellipse.Effect>
                    </Ellipse>

                    <TextBlock x:Name="CurrentBookText"
                         TextTrimming="CharacterEllipsis"
                         TextWrapping="NoWrap"
                         ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"
                         Foreground="#fcb5ae"
                         FontSize="10"
                         FontWeight="Bold"
                         HorizontalAlignment="Center"
                         FontFamily="JetBrainsMono Nerd Font" />

                    <TextBlock x:Name="CurrentBookProgressText"
                          Text="..."
                          Foreground="#CBA6F7"
                          FontSize="8"
                          FontWeight="Bold"
                          HorizontalAlignment="Center"
                          FontFamily="JetBrainsMono Nerd Font" />

                    <TextBlock x:Name="CurrentBookChapterText" 
                               HorizontalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap"
                               FontFamily="JetBrainsMono Nerd Font"
                               FontSize="8"
                               Foreground="#CBA6F7"
                               />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Anime Card -->
        <Border Grid.Row="1"
            Margin="0,5,0,5"
            CornerRadius="5"
            ClipToBounds="True"
            Padding="4"
            x:Name="animeCard"
            Style="{StaticResource AnimatedCardStyle}"
            RenderTransformOrigin="0.5,0.5">

            <Border.RenderTransform>
                <TransformGroup>
                    <SkewTransform x:Name="CardSkew"/>
                    <ScaleTransform x:Name="CardScale"/>
                </TransformGroup>
            </Border.RenderTransform>


            <Image Source="/Assets/Wallpapers/columbinaheader.jpg"
                   Stretch="UniformToFill"
                   Name="AnimeImage" 
                   Margin="2"
                   RenderTransformOrigin="0.5,0.5">
            </Image>

        </Border>

        <!-- Main Apps -->
        <UniformGrid Grid.Row="2"
                 Columns="3" Height="80" Margin="0,0,0,160" Grid.RowSpan="2" VerticalAlignment="Bottom">

            <Button Margin="2.5" Style="{StaticResource animeButtonStyle}" Name="ZenNotes" Click="zenNotesClick"> 
                <Image Height="20" Width="20" Source="/Assets/AnimeSets/material-symbols--note.png" ToolTip="ZenNotes"/>
            </Button>
            <Button Margin="2.5" Style="{StaticResource animeButtonStyle}" Name="button1">
                <Image gif:ImageBehavior.AnimatedSource ="Assets/AnimeSets/kurukuru.gif" Height="50" Width="50"></Image></Button>
            <Button Margin="2.5" Style="{StaticResource animeButtonStyle}" Name="button2">🌐</Button>
        </UniformGrid>

        <!-- Other Apps -->
        <UniformGrid Grid.Row="3"
                 Columns="4">

            <Button Margin="2.5" Name = "Koodo" Click="koodoClick" Style="{StaticResource animeButtonStyle}">
                <Image Height="20" Width="20" Source="/Assets/AnimeSets/tabler--books.png" />
            </Button>
            <Button Margin="2.5" Name = "VSCode" Click ="vsCodeClick" Style="{StaticResource animeButtonStyle}">
                <Image Height="20" Width="20" Source="/Assets/AnimeSets/catppuccin--vscode.png" />
            </Button>
            <Button Margin="2.5" Name = "Zen" Click = "zenClick" Style="{StaticResource animeButtonStyle}">
                <Image Height="20" Width="20" Source="/Assets/AnimeSets/simple-icons--zenbrowser.png" />
            </Button>
            <Button Margin="2.5" Name = "Spotify" Click="spotifyClick" Style="{StaticResource animeButtonStyle}">
                <Image Height="20" Width="20" Source="/Assets/AnimeSets/selfhst--spotify-for-creators.png" />
            </Button>

            <Button Margin="5" Style="{StaticResource animeButtonStyle}" Name="hoYo" Click="hoyoClick">
                <Image Height="40" Width="40" Source="/Assets/AnimeSets/simple-icons--mihoyo.png"/>
            </Button>
            <Button Margin="5" Style="{StaticResource animeButtonStyle}" Name="gallery" Click="galleryClick">
                <Image Height="20" Width="20" Source="/Assets/AnimeSets/solar--gallery-bold-duotone.png"/>
            </Button>
            <Button Margin="5" Style="{StaticResource animeButtonStyle}" Name="gimp" Click="gimpClick">
                <Image Height="20" Width="20" Source="/Assets/AnimeSets/simple-icons--gimp.png" />
            </Button>
            <Button Margin="5" Style="{StaticResource animeButtonStyle}" Name="visualStudio" Click="visualStudioClick">
                <Image Width="20" Height="20" Source="/Assets/AnimeSets/catppuccin--visual-studio.png" />
            </Button>
        </UniformGrid>

        <!-- Bottom Toggles -->
        <Border Grid.Row="4"
        Margin="0,5,0,0"
        CornerRadius="5"
        ClipToBounds="True"
        Padding="5"
        Style="{StaticResource AnimatedCardStyle}"
        x:Name="bottomAnimeCard">

            <Grid>

                <!-- Anime Image -->
                <Image Source="/Assets/AnimeSets/header5.jpg"
               Stretch="UniformToFill"
               Margin="1"/>

                <!-- Optional dark fade -->
                <Border VerticalAlignment="Bottom"
                Height="70">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#00000000" Offset="0"/>
                            <GradientStop Color="#AA000000" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Visualizer -->
                <UniformGrid x:Name="VisualizerGrid"
             Columns="48"
             Margin="12,-10,12,7"/>

            </Grid>

        </Border>
    </Grid>
</Window>